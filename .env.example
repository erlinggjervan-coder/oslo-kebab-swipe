# Den aktive RULL-appen krever ingen hemmelige miljøvariabler.
# Alle variablene nedenfor er valgfrie innstillinger for lokal verktøykjøring.

CODEX_SANDBOX=
WRANGLER_WRITE_LOGS=
WRANGLER_LOG_PATH=
MINIFLARE_REGISTRY_PATH=
SITES_RUNTIME_ROOT=
SITES_NPM_CACHE_SEED=
SITES_INSTALL_TIMEOUT=
SITES_INSTALL_KILL_AFTER=
SITES_BUILD_TIMEOUT=
SITES_BUILD_KILL_AFTER=

# Interne verdier som normalt settes av scripts/sites-env.sh, ikke av brukeren:
SITES_ENV_READY=
SITES_PROJECT_ROOT=

# Cloudflare ASSETS og IMAGES er plattformbindinger, ikke .env-hemmeligheter.
# DB er bare en plattformbinding dersom valgfri D1 senere aktiveres.
